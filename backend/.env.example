# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME=SAAM Backend
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Firebase ─────────────────────────────────────────────────────────────────
# Opción A: ruta al archivo serviceAccountKey.json
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json
# Opción B: campos individuales (usar si no hay archivo)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=###
VITE_SUPABASE_ANON_KEY=###
SUPABASE_BUCKET_PDFS=pdfs
SUPABASE_BUCKET_XLSX=xlsx

# ── Gemini — un API key por motor ────────────────────────────────────────────
GEMINI_COSO_API_KEY=
GEMINI_COBIT_API_KEY=
GEMINI_RGSI_API_KEY=
GEMINI_CHAT_API_KEY=
GEMINI_MATURITY_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
